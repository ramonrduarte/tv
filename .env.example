# Copie este arquivo para .env e preencha os valores

# Gere uma chave forte: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=troque-por-uma-chave-secreta-forte-aqui

# Em produção, sempre False
DEBUG=False

# IP ou domínio do servidor (sem http://)
# Ex: 192.168.1.100,iptv.seudominio.com
ALLOWED_HOSTS=localhost,127.0.0.1,seu-ip-do-servidor

# Origens permitidas para formulários (com protocolo)
# Ex: https://iptv.seudominio.com ou http://192.168.1.100:8080
CSRF_TRUSTED_ORIGINS=http://seu-ip-do-servidor:8080

# Banco de dados PostgreSQL
DB_NAME=iptv
DB_USER=postgres
DB_PASSWORD=coloque-uma-senha-forte-aqui
DB_HOST=ip-ou-hostname-do-banco
DB_PORT=5432

# Token para a API do agente WhatsApp
# Gere um valor aleatório: python -c "import secrets; print(secrets.token_hex(32))"
API_TOKEN_WHATSAPP=token-secreto-para-api-whatsapp
